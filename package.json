{
  "name": "recipe-backend",
  "version": "2.0.0",
  "description": "Backend API for PersonalCookingRecipe with Context7 integration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:context7": "jest src/context7/integration-tests.js --verbose",
    "test:performance": "jest src/context7/integration-tests.js --testNamePattern='Performance'",
    "test:security": "jest src/context7/integration-tests.js --testNamePattern='Security'",
    "test:coverage": "jest --coverage",
    "seed": "node src/utils/seed.js",
    "context7:init": "node src/context7/scripts/initialize.js",
    "context7:start": "node src/context7/scripts/start.js",
    "context7:backup": "node src/context7/scripts/backup.js",
    "context7:memory-stats": "node src/context7/scripts/memory-stats.js",
    "context7:collect-metrics": "node src/context7/scripts/collect-metrics.js",
    "context7:performance-report": "node src/context7/scripts/performance-report.js",
    "dev:context7": "nodemon src/context7/scripts/dev-server.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^4.6.8",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.27.11",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "chai": "^6.2.1",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "sinon": "^21.0.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/utils/seed.js",
      "!src/context7/scripts/**",
      "!src/**/*.test.js",
      "!src/tests/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "<rootDir>/src/context7/test-setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/tests/**/*.test.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "personalcookingrecipe",
    "context7",
    "multi-layer-context",
    "recipe-management",
    "ai-collaboration",
    "multimodal-processing"
  ],
  "author": "Recipe-CTO Team",
  "license": "PROPRIETARY"
}
