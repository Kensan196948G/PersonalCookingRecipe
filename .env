PORT=5000
NODE_ENV=development
JWT_SECRET=phase1_emergency_jwt_secret_key_32chars_minimum
JWT_CACHE_ENABLED=false
JWT_CACHE_TTL=3600

# Database Configuration (SQLite)
DATABASE_PATH=./data/recipes.db

# Redis Configuration (Disabled for local)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Monitoring (Disabled for local simple setup)
ERROR_DETECTION_ENABLED=false
MONITOR_DATABASE=false
MONITOR_REDIS=false
MONITOR_MEMORY=false
MONITOR_API=false
ALERT_CONSOLE_ENABLED=true